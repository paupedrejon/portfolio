# =============================================================================
# Copia a .env.local (desarrollo) — NO subas .env.local a git
# En Vercel: Project → Settings → Environment Variables (mismas claves)
# =============================================================================

# --- Google OAuth (Google Cloud Console → Credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- NextAuth (obligatorio en este proyecto) ---
# URL donde abres el portfolio en el navegador, SIN barra final al final
# Local (elige la que uses): http://localhost:3000  o  http://localhost:3001
# Producción: https://www.paupedrejon.com
NEXTAUTH_URL=http://localhost:3000

# URL pública del sitio (SEO: sitemap, canonical, Open Graph)
# Producción: https://www.paupedrejon.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Generar secret: openssl rand -base64 32

# --- Study Agents (backend Python) ---
FASTAPI_URL=http://localhost:8000
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000

# --- APIs de IA (Study Agents / cursos) ---
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Formulario de contacto ---
GMAIL_USER=
GMAIL_APP_PASSWORD=

# =============================================================================
# CURSO DE REACT — Base de datos en la nube (configuras TÚ, el alumno no ve esto)
# Guía paso a paso: CURSOS_SETUP.md
# =============================================================================
# Supabase → Settings → API → "Project URL" (NO el connection string postgresql)
# Correcto:  https://TU-PROYECTO.supabase.co
# Incorrecto: https://TU-PROYECTO.supabase.co/rest/v1/  (eso lo añade el SDK solo)
# Secret key (sb_secret_...) → SUPABASE_SERVICE_ROLE_KEY
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# URL de TU web (va dentro del zip del alumno). Producción:
# COURSE_API_BASE_URL=https://www.paupedrejon.com
COURSE_API_BASE_URL=http://localhost:3000
